# Local .terraform working directory (contains plugins and modules)
.terraform/

# Local state files (containing sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files (often contain secrets/credentials)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

